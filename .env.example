# Postgres connection string (Railway provides this in production)
DATABASE_URL="postgres://user:password@localhost:5432/better_pdf_web"

# Better Auth — generate with: npx auth secret
BETTER_AUTH_SECRET="replace-with-32+-char-random-secret"
BETTER_AUTH_URL="http://localhost:5173"

# Google OAuth — optional. The Google provider is only enabled when BOTH are set.
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: $BETTER_AUTH_URL/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
