# Postgres connection string.
#
# Local dev: a plain local/Railway Postgres works.
DATABASE_URL="postgres://user:password@localhost:5432/better_pdf_web"
#
# Netlify + Neon (serverless): set DATABASE_URL in the Netlify dashboard to
# Neon's POOLED endpoint — host contains "-pooler", ends with ?sslmode=require.
# Required because Functions are short-lived; the runtime client uses
# prepare:false to work behind Neon's PgBouncer (transaction mode).
#   DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.us-east-1.aws.neon.tech/db?sslmode=require"
#
# Migrations & seeding (drizzle-kit) need prepared statements, so run them
# against Neon's DIRECT endpoint (no "-pooler"):
#   DATABASE_URL="postgresql://...@ep-xxx.us-east-1.aws.neon.tech/db?sslmode=require" bun run db:migrate
# Pick the Neon region (us-east-1) matching Netlify Functions to minimize latency.

# Better Auth — generate with: npx auth secret
BETTER_AUTH_SECRET="replace-with-32+-char-random-secret"
BETTER_AUTH_URL="http://localhost:5173"

# Google OAuth — optional. The Google provider is only enabled when BOTH are set.
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: $BETTER_AUTH_URL/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Lemon Squeezy billing (merchant-of-record). Use TEST-mode keys/store/variants
# while developing; switch to live values for production.
# API key: LS Dashboard → Settings → API.
LEMONSQUEEZY_API_KEY=""
# Store id (numeric): LS Dashboard → Settings → Stores.
LEMONSQUEEZY_STORE_ID=""
# Webhook signing secret: LS Dashboard → Settings → Webhooks (the secret you set
# when creating the webhook pointed at $BETTER_AUTH_URL/api/billing/webhook).
LEMONSQUEEZY_WEBHOOK_SECRET=""
# Variant ids (numeric) for the Pro product's monthly and annual prices.
LEMONSQUEEZY_VARIANT_PRO_MONTHLY=""
LEMONSQUEEZY_VARIANT_PRO_ANNUAL=""
